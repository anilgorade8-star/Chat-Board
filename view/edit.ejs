<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Chat</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="page">
        <h1>Edit Chat</h1>

        <div class="toolbar">
            <a href="/chats">Back to Chats</a>
        </div>

        <form method="post" action="/chats/<%= chat._id %>">
        <label>From</label>
        <input type="text" name="from" value="<%= chat.from %>" required />

        <label>To</label>
        <input type="text" name="to" value="<%= chat.to %>" required />

        <label>Message</label>
        <textarea name="message" required><%= chat.message %></textarea>

        <button type="submit">Save Changes</button>
        </form>
    </div>
</body>
</html>